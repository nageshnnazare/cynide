# Arithmetic & numeric expressions

let i_sum = 17 + 5
let i_sub = 17 - 5
let i_mul = 6 * 9
let i_div = 20 / 4
print(i_sum, i_sub, i_mul, i_div)

let i_mod = 18 % 3
print(i_mod)

let neg = -(3 + 2)
let x = -10
print(neg, x)

let paren = (2 + 3) * 4
let prec = 1 + 2 * 3
print(paren, prec)

let m = 10 + 3.5
let n = 20.0 / 8
print(m, n)
